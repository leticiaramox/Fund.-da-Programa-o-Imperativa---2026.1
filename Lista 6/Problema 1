#include <stdio.h>
#include <stdlib.h>
#include <math.h>

void dobro(int** m, int n1, int n2) {
    for (int i = 0; i < n1; i++)
        for (int j = 0; j < n2; j++)
            m[i][j] *= 2;
}

void quadrado(int** m, int n1, int n2) {
    for (int i = 0; i < n1; i++)
        for (int j = 0; j < n2; j++)
            m[i][j] = m[i][j] * m[i][j];
}

void absoluto(int** m, int n1, int n2) {
    for (int i = 0; i < n1; i++)
        for (int j = 0; j < n2; j++)
            m[i][j] = abs(m[i][j]);
}

void liberar(int** m, int linhas) {
    if (m == NULL) {
        free(m);
        return;
    } 
    for (int i = 0; i < linhas; i++) free(m[i]);
    free(m);
}

int main() {
    int n1, n2;
    if (scanf("%d %d", &n1, &n2) != 2) return 1;

    int** matriz = (int**) malloc(n1 * sizeof(int*));
    if (matriz == NULL) {
        free(matriz);
        return 1;
    }

    for (int i = 0; i < n1; i++) {
        matriz[i] = (int*) malloc(n2 * sizeof(int));
        if (matriz[i] == NULL) {
            liberar(matriz, i);
            return 1;
        }
        for (int j = 0; j < n2; j++) {
            scanf("%d", &matriz[i][j]); 
        }
    }

    int operacao;
    scanf("%d", &operacao);

    int** copia = (int**) malloc(n1 * sizeof(int*));
    if (copia == NULL) {
        liberar(matriz, n1);
        free(copia);
        return 1;
    }

    for (int i = 0; i < n1; i++) {
        copia[i] = (int*) malloc(n2 * sizeof(int));
        if (copia[i] == NULL) {
            liberar(copia, i);
            liberar(matriz, n1);
            return 1;
        }

        for (int j = 0; j < n2; j++) {
            copia[i][j] = matriz[i][j];
        }
    }

    if (operacao == 1) dobro(copia, n1, n2);
    else if (operacao == 2) quadrado(copia, n1, n2);
    else absoluto(copia, n1, n2);

    for (int i = 0; i < n1; i++) {
        for (int j = 0; j < n2; j++) {
            printf("%d ", copia[i][j]);
        }
        printf("\n");
    }

    liberar(matriz, n1);
    liberar(copia, n1);

    return 0;
}
