void dano1(int** matriz, int x, int y, int n1, int n2);
void dano2(int** matriz, int x, int y, int n1, int n2);

void liberar(int** m, int linhas) {
    if (m == NULL) {
        free(m);
        return;
    } 
    for (int i = 0; i < linhas; i++) free(m[i]);
    free(m);
}


