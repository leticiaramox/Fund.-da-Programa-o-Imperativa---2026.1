void dano1 (int** copia, int x, int y, int n1, int n2) {

    for (int i = 0; i < n1; i++) {
        for (int j = 0; j < n2; j++) {
            int dano_tomado = 0;
            if (i < x - 2 || i > x + 2 || j < y - 2 || j > y + 2 || (abs(i - x) == 2 && abs(j - y) == 2)) continue;
            if (((abs(i - x) <= 1 && abs(j - y) <= 1) && (abs(i - x) != abs(j - y))) || x == i && y == j) {
                dano_tomado = 50;
            } else {
                dano_tomado = 25;
            }
            
            copia[i][j] -= dano_tomado;
        } 
    }

    for (int i = 0; i < n1; i++) {
        for (int j = 0; j < n2; j++) {
            if (copia[i][j] < 0) {
                copia[i][j] = 0;
            }
        }

    }

}


void conta_vizinhos (int** copia, int x, int y, int n1, int n2, int vizinhos[][n2]) {
    for (int l = 0; l < n1; l++) {
        for (int m = 0; m < n2; m++) {
            for (int i = -1; i <= 1; i++) {
                for (int j = -1; j <= 1; j++) {
                    if (0 <= l + i && l + i < n1 && 0 <= m + j && m + j < n2 && copia[l + i][m + j] > 0) {
                        vizinhos[l][m]++;
                    }
                }
            }
        }
    }
}

void dano2 (int** copia, int x, int y, int n1, int n2) {
    for (int k = 0; k < 3; k++) {

        int vizinhos_vivos = -1;
        for (int i = -1; i <= 1; i++) {
            for (int j = -1; j <= 1; j++) {
                if (0 <= x + i && x + i < n1 && 0 <= y + j && y + j < n2 && copia[x + i][y + j] > 0) {
                    vizinhos_vivos++;
                }
            }
        }

        int vizinhos[n1][n2];
        for (int l = 0; l < n1; l++) {
            for (int m = 0; m < n2; m++) {
                vizinhos[l][m] = -1;
            }
        }

        conta_vizinhos (copia, x, y, n1, n2, vizinhos);

        for (int i = 0; i < n1; i++) {
            for (int j = 0; j < n2; j++) {
                if (i < x - 2 || i > x + 2 || j < y - 2 || j > y + 2 || (abs(i - x) == 2 && abs(j - y) == 2)) continue; 
                int dano_tomado = 5 + (8 * vizinhos[i][j]);
                copia[i][j] -= dano_tomado;
            }
        }

        for (int i = 0; i < n1; i++) {
            for (int j = 0; j < n2; j++) {
                if (copia[i][j] < 0) {
                    copia[i][j] = 0;
                }
            }
        }

        if (vizinhos_vivos != -1) {
            for (int i = 0; i < n1; i++) {
                for (int j = 0; j < n2; j++) {
                    printf("%d ", copia[i][j]);
                    if (j == n2 - 1 && n2 > 1) {
                        printf("\n");
                    }
                }
            }
            puts(" ");
            if (n2 == 1) {
                puts(" ");
            }
        } else {
            break;
        }
    }
}
