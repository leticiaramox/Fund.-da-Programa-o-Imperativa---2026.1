#include <stdio.h>

void padrao(int n1, int n2, char saida[][n2 + 1]) {
    for (int i = 0; i < n1; i++) {
        for (int j = 0; j < n2; j++) {
            if (saida[i][j] == 'o') {
                // 1. Tenta descer
                if (i + 1 < n1 && saida[i + 1][j] == '.') {
                    saida[i + 1][j] = 'o';
                }
                // se bater em prateleira, espalha pros lados
                else if (i + 1 < n1 && saida[i + 1][j] == '#') {
                    // Espalha para a esquerda
                    if (j - 1 >= 0 && saida[i][j - 1] == '.') {
                        saida[i][j - 1] = 'o';
                    }
                    // Espalha para a direita
                    if (j + 1 < n2 && saida[i][j + 1] == '.') {
                        saida[i][j + 1] = 'o';
                    }
                }
            }
        }
    }
}

int main() {
    int n1, n2;
    if (scanf("%d %d", &n1, &n2) != 2) return 0;

    char saida[n1][n2 + 1];

    for (int i = 0; i < n1; i++) {
        scanf("%s", saida[i]);
    }

    // o número de iterações garante que a água percorra todo o caminho
    for (int t = 0; t < n1 * n2; t++) {
        // em termos de fluxo, n1 * n2 é o máximo de passos possíveis
        padrao(n1, n2, saida);
    }

    for (int i = 0; i < n1; i++) {
        printf("%s\n", saida[i]);
    }

    return 0;
}
