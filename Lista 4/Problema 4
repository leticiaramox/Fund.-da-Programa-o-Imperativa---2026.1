#include <stdio.h>
#include <stdbool.h>

int dr[] = {1, -1, 0, 0};
int dc[] = {0, 0, 1, -1};
int min_passos = 1000000;
bool encontrou = false;

void buscar_saida(int r, int c, int dist, int n1, int n2, char mapa[n1][n2 + 1], int visitado[n1][n2]) {
    if (r < 0 || r >= n1 || c < 0 || c >= n2 || mapa[r][c] == '#' || dist >= min_passos || dist >= visitado[r][c]) {
        return;
    }

    if (mapa[r][c] == 'd') {
        encontrou = true;
        min_passos = dist;
        return;
    }

    // rgistra que chegamos aqui com essa quantidade de passos
    visitado[r][c] = dist;

    for (int i = 0; i < 4; i++) {
        buscar_saida(r + dr[i], c + dc[i], dist + 1, n1, n2, mapa, visitado);
    }
}

int main() {
    int n1, n2;
    if (scanf("%dx%d", &n1, &n2) != 2) return 0;

    char mapa[n1][n2 + 1];
    int visitado[n1][n2]; // matriz de inteiros

    int start_r, start_c;

    for (int i = 0; i < n1; i++) {
        scanf("%s", mapa[i]);
        for (int j = 0; j < n2; j++) {
            if (mapa[i][j] == 'o') {
                start_r = i;
                start_c = j;
            }
            // inicializamos com um valor muito alto (infinito)
            visitado[i][j] = 1000000;
        }
    }

    buscar_saida(start_r, start_c, 0, n1, n2, mapa, visitado);

    if (encontrou) {
        printf("Apos correr %d metros e quase desistir por causa da distância, Rebeka conseguiu escapar!\n", min_passos);
    } else {
        printf("Poxa... Parece que nao foi dessa vez que Rebeka conseguiu fugir\n");
    }

    return 0;
}
