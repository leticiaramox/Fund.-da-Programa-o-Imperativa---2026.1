            maior_tamanho = comprimento[i];
        }
    }

    int soma = 0;
    for (int i = 0; i < N; i++) {
        soma += comprimento[i];
    }

    // soma é o total de letras de todas as palavras lidas
    char *mensagem_final = malloc((soma + 1) * sizeof(char));
    int k = 0; // Índice para controlar a posição na nova string
    int freq[26] = {0};


    if (mensagem_final != NULL) {
        for (int j = 0; j < maior_tamanho; j++) {
        
            for (int i = 0; i < N; i++) {
                if (j < comprimento[i]) {

                    printf("%c", lista_palavras[i][j]);

                    char letra_atual = lista_palavras[i][j];
            
                    // 1. Guarda na nossa nova string
                    mensagem_final[k++] = letra_atual;

                }
            }
        }
    }


    printf("\n");

    // chama a função de fusão
    while (ainda_tem_repetido(mensagem_final)) {
        fundirCircular(mensagem_final);
    }


    // imprime a mesnagem modificada
    for (int k = 0; mensagem_final[k] != '\0'; k++) {
        printf("%c", mensagem_final[k]);
    }

    printf("\n");

    for (int i = 0; i < N; i++) {
        free(lista_palavras[i]);
    }
}
