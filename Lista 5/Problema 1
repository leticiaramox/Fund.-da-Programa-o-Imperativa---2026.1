#include <stdio.h>
#include <stdlib.h>
#include <string.h>

// após a fusão, todos os carcteres andam 1 para a esquerda
void troca(char *mensagem_final, int i) {
    int j;
    // começamos de i + 1 para remover a letra duplicada que foi fundida
    for (j = i + 1; mensagem_final[j] != '\0'; j++) {
        mensagem_final[j] = mensagem_final[j + 1];
    }
}

void fundirCircular(char *mensagem_final) {
    int i = 0;
    
    while (mensagem_final[i] != '\0' && mensagem_final[i+1] != '\0') {
        
        // se as letras vizinhas são iguais
        if (mensagem_final[i] == mensagem_final[i + 1]) {
            
            // transforma a letra na próxima (com giro de z para a)
            int valor = mensagem_final[i] - 'a';
            mensagem_final[i] = ((valor + 1) % 26) + 'a';
            
            // remove a letra repetida da direita
            troca(mensagem_final, i);

        }

        // avançando...
        i++;
    }
}

int ainda_tem_repetido(char *s) {
    for (int i = 0; s[i] != '\0' && s[i+1] != '\0'; i++) {
        if (s[i] == s[i+1]) {
            return 1; // par igual
        }
    }
    return 0; // todos são diferentes.
}



