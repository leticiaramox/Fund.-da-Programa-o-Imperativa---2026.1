#include <stdio.h>
#include <stdlib.h>

double media(double *notas, int N) {
    double soma = 0;
    for (int i = 0; i < N; i++) {
        soma += notas[i];
    }
    return (N > 0) ? (soma / N) : 0;
}

void ordenar_e_extrair(double *notas, int *indices, int N) {
    for (int i = 0; i < N - 1; i++) {
        for (int j = 0; j < N - i - 1; j++) {
            if (notas[j] < notas[j + 1]) {
                double holdNota = notas[j];
                notas[j] = notas[j + 1];
                notas[j + 1] = holdNota;

                int holdIndice = indices[j];
                indices[j] = indices[j + 1];
                indices[j + 1] = holdIndice;
            }
        }
    }
}

void moda(double *notas, int *freq, int N, double *mais_aparece, int *mais_de_um) {
    int max_freq = 0;
    
    for (int i = 0; i < N; i++) {
        freq[i] = 0;
        for (int j = 0; j < N; j++) {
            if (notas[i] == notas[j]) {
                freq[i]++;
            }
        }
        if (freq[i] > max_freq) {
            max_freq = freq[i];
            *mais_aparece = notas[i];
        }
    }

    if (max_freq <= 1) {
        *mais_de_um = 1;
        return;
    }

    for (int i = 0; i < N; i++) {
        if (freq[i] == max_freq && notas[i] != *mais_aparece) {
            *mais_de_um = 1;
            return;
        }
    }
    
    *mais_de_um = 0;
}

int main() {

    // PRIMEIRO RELATÓRIO


    int N1 = 0;
    
    if (scanf("%d", &N1) != 1) return 0;

    int num = N1;

    double *notas = malloc(N1 * sizeof(double));
    int *indices = malloc(N1 * sizeof(int));
    if (notas == NULL || indices == NULL) exit(1);

    for (int i = 0; i < N1; i++) {
        scanf("%lf", &notas[i]);
        indices[i] = i + 1;
    }

    puts("Relatorio inicial");
    printf("Media: %.2f\n", media(notas, N1));
    
    int menor = 0;
    int nota_menor;
    for (int i = 1; i < N1; i++) {
        if (notas[menor] > notas[i]) {
            menor = i;
        }
    }

    menor++;

    ordenar_e_extrair(notas, indices, N1);
    

    printf("Maior nota: %.2f (aluno %d)\n", notas[0], indices[0]);
    printf("Menor nota: %.2f (aluno %d)\n", notas[N1 - 1], menor);

    nota_menor = notas[N1 - 1];

    double mediana;
    if (N1 % 2 != 0) mediana = notas[N1 / 2];
    else mediana = (notas[(N1 / 2) - 1] + notas[N1 / 2]) / 2.0;

    int acima_da_media = 0;
    for (int i = 0; i < N1; i++) {
        if (notas[i] > media(notas, N1)) acima_da_media++;
    }

    printf("Acima da media: %d\n", acima_da_media);
    printf("Mediana: %.2f\n", mediana);

    int *freq = calloc(N1, sizeof(int));
    double v_mais_aparece = 0;
    int mais_de_um = 0;
    moda(notas, freq, N1, &v_mais_aparece, &mais_de_um);

    if (mais_de_um) puts("Moda: Nao ha moda unica");
    else printf("Moda: %.2f\n", v_mais_aparece);


    // SEGUNDO RELATÓRIO


    printf("\n");

    int N2;
    if (scanf("%d", &N2) != 1) {
        free(notas); free(indices); free(freq);
        return 0;
    }

    double *temp_n = realloc(notas, (N1 + N2) * sizeof(double));
    if (temp_n == NULL) exit(1);
    notas = temp_n;

    int *temp_i = realloc(indices, (N1 + N2) * sizeof(int));
    if (temp_i == NULL) exit(1);
    indices = temp_i;

    for (int i = N1; i < N1 + N2; i++) {
        scanf("%lf", &notas[i]);
        indices[i] = i + 1;
    }

    N1 += N2;

    puts("Relatorio atualizado");
    printf("Media: %.2f\n", media(notas, N1));

    int atualizou = 0;

    for (int i = num; i < N1; i++) {
        if (notas[i] < nota_menor) {
            menor = i;
            atualizou = 1;
        }
    }

    if (atualizou) {
        menor++;
    }

    ordenar_e_extrair(notas, indices, N1);
    
    printf("Maior nota: %.2f (aluno %d)\n", notas[0], indices[0]);
    printf("Menor nota: %.2f (aluno %d)\n", notas[N1 - 1], menor);

    if (N1 % 2 != 0) mediana = notas[N1 / 2];
    else mediana = (notas[(N1 / 2) - 1] + notas[N1 / 2]) / 2.0;

    acima_da_media = 0;
    for (int i = 0; i < N1; i++) {
        if (notas[i] > media(notas, N1)) acima_da_media++;
    }

    printf("Acima da media: %d\n", acima_da_media);
    printf("Mediana: %.2f\n", mediana);

    int *temp_f = realloc(freq, N1 * sizeof(int));
    if (temp_f == NULL) exit(1);
    freq = temp_f;

    v_mais_aparece = 0;
    mais_de_um = 0;
    moda(notas, freq, N1, &v_mais_aparece, &mais_de_um);

    if (mais_de_um) puts("Moda: Nao ha moda unica");
    else printf("Moda: %.2f\n", v_mais_aparece);

    printf("\n");

    free(notas);
    free(indices);
    free(freq);

    return 0;
}
