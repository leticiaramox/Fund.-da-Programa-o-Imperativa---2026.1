#include <stdio.h>
#include <stdlib.h>

int main () {
    // inserindo a entrada...
    int x = 0, y = 0, Q = 0;
    scanf("%d %d %d", &x, &y, &Q);
    // quadrante inicial e o destino
    int q = 0, qDestino = 0;
    if ((x > 0) && (y > 0)) {
        q = 1;
    } else if ((x > 0) && (y < 0)) {
        q = 4;
    } else if ((x < 0) && (y > 0)) {
        q = 2;
    } else if ((x < 0) && (y < 0)) {
        q = 3;
    };

    // flag de caminho impossivel
    int impossivel = 0;
    if ((q == 1) && (Q == 3)) {
        impossivel = 1;
    } else if ((q == 2) && (Q == 4)) {
        impossivel = 1;
    } else if ((q == 3) && (Q == 1)) {
        impossivel = 1;
    } else if ((q == 4) && (Q == 2)) {
        impossivel = 1;
    } else if (q == Q) {
        impossivel = 1;
    };

    // print da caminhada inválida
    if (impossivel == 1) {
        printf("caminhada invalida\n");
    } else {
        // processo para caminhadas válidas
        // achando a diagonal
        qDestino = ((q + 2) % 4);
        if (qDestino == 0) {
            qDestino = 4;
        };
        // achando as coordenadas do destino
        int xDestino = 0, yDestino = 0;
        if (qDestino == 1) {
            xDestino = 1;
            yDestino = 1;
        } else if (qDestino == 2) {
            xDestino = -1;
            yDestino = 1;
        } else if (qDestino == 3) {
            xDestino = -1;
            yDestino = -1;
        } else if (qDestino == 4) {
            xDestino = 1;
            yDestino = -1;
        };
        // número de passos do caminho percorrido
        int Dx = 0, Dy = 0;
        Dx = abs(x - xDestino);
        Dy = abs(y - yDestino);
        // sequência seguida durante o trajeto
        int primeiro = 0, segundo = 0;
        char coord1, coord2;
        if (q == 4) {
            if (Q == 1) {
                primeiro = Dx;
                coord1 = 'x';
                segundo = Dy;
                coord2 = 'y';
            } else if (Q == 3) {
                primeiro = Dy;
                coord1 = 'y';
                segundo = Dx;
                coord2 = 'x';
            };
        } else if (q == 1) {
            if (Q == 4) {
                primeiro = Dx;
                coord1 = 'x';
                segundo = Dy;
                coord2 = 'y';
            } else if (Q == 2) {
                primeiro = Dy;
                coord1 = 'y';
                segundo = Dx;
                coord2 = 'x';
            };
        } else {
            if (Q > q) {
                primeiro = Dy;
                coord1 = 'y';
                segundo = Dx;
                coord2 = 'x';
            } else {
                primeiro = Dx;
                coord1 = 'x';
                segundo = Dy;
                coord2 = 'y';
            };
        }; 
        printf("%d passos em %c e %d passos em %c\n", primeiro, coord1, segundo, coord2);
    };
}


